{
  "manifest_version": 3,
  "name": "Auto Fill Profile",
  "version": "1.0.0",
  "description": "Zoom・セミナー・Google Form 等のフォームにプロフィール情報を自動入力します",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
